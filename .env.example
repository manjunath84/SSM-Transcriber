# ── Transcription ────────────────────────────────────────────────────────────
# Local faster-whisper model size: tiny | base | small | medium | large-v3
# Default: base  (good balance of speed and accuracy, no API key needed)
WHISPER_MODEL_SIZE=base

# Device for faster-whisper: auto | cpu | cuda
WHISPER_DEVICE=auto

# Cloud transcription provider (Phase 5+): faster_whisper | deepgram | assemblyai | openai_whisper
# Default: faster_whisper  (local, free, no API key needed)
TRANSCRIPTION_PROVIDER=faster_whisper

# Budget ceiling: free | low | best
# free = local only (default), low = cheapest cloud fallback, best = best available
DEFAULT_BUDGET=free

# ── Cloud transcription API keys (only set the one you use) ──────────────────
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=

# ── LLM (Phase 6+ — for --summarize and --clean flags) ───────────────────────
# LiteLLM model string — any provider supported by litellm
# Default: groq/llama-3.1-8b-instant  (free tier, ~100K tokens/day)
TRANSCIBER_LLM_MODEL=groq/llama-3.1-8b-instant

GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ── Paths ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
CACHE_DIR=~/.cache/transciber
CACHE_ENABLED=true

# ── Google Drive (Phase 4+) ───────────────────────────────────────────────────
GOOGLE_CLIENT_SECRETS_FILE=~/.config/transciber/google_client_secrets.json
GOOGLE_TOKEN_FILE=~/.config/transciber/google_token.json

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
