# ─────────────────────────────────────────────────────────────────────────────
# Internal Transcriber settings (all prefixed TRANSCRIBER_)
# Read via pydantic-settings in src/transcriber/config.py
# ─────────────────────────────────────────────────────────────────────────────

# Local faster-whisper model size: tiny | base | small | medium | large-v3
# Default: base  (good balance of speed and accuracy, no API key needed)
TRANSCRIBER_WHISPER_MODEL_SIZE=base

# Device for faster-whisper: auto | cpu | cuda
TRANSCRIBER_WHISPER_DEVICE=auto

# Cloud transcription provider (Phase 5+): faster_whisper | deepgram | assemblyai | openai_whisper
# Default: faster_whisper  (local, free, no API key needed)
TRANSCRIBER_TRANSCRIPTION_PROVIDER=faster_whisper

# Budget ceiling: free | low | best
# free = local only (default), low = cheapest cloud fallback, best = best available
TRANSCRIBER_DEFAULT_BUDGET=free

# Paths
TRANSCRIBER_OUTPUT_DIR=./output
TRANSCRIBER_CACHE_DIR=~/.cache/transcriber
TRANSCRIBER_CACHE_ENABLED=true

# LLM (Phase 6a+ — only used with --summarize / --clean flags)
# LiteLLM model string — any provider supported by litellm
# Default: groq/llama-3.1-8b-instant  (free tier, ~100K tokens/day)
TRANSCRIBER_LLM_MODEL=groq/llama-3.1-8b-instant

# Logging
TRANSCRIBER_LOG_LEVEL=INFO

# Google Drive paths (Phase 4+)
TRANSCRIBER_GOOGLE_CLIENT_SECRETS_FILE=~/.config/transcriber/google_client_secrets.json
TRANSCRIBER_GOOGLE_TOKEN_FILE=~/.config/transcriber/google_token.json

# ─────────────────────────────────────────────────────────────────────────────
# Third-party API keys (unprefixed — vendor SDKs read these directly)
# Only set the ones you actually use.
# ─────────────────────────────────────────────────────────────────────────────

# Transcription
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
OPENAI_API_KEY=

# LLM providers (cheapest-first fallback chain)
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
